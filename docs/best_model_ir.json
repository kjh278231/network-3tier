{
  "problem_type": "three_tier_network_design",
  "model_variant": "best_model",
  "objective_sense": "min_total_cost",
  "sets": [
    {
      "name": "plants",
      "symbol": "P",
      "description": "공급 거점 plant 집합",
      "source": "plant sheet"
    },
    {
      "name": "warehouses",
      "symbol": "W",
      "description": "활성 warehouse 후보 집합",
      "source": "warehouse sheet filtered by Active Y/N in {Y, F}"
    },
    {
      "name": "customers",
      "symbol": "C",
      "description": "수요 customer 집합",
      "source": "customer sheet"
    },
    {
      "name": "plant_warehouse_arcs",
      "symbol": "A_pw",
      "description": "plant -> warehouse 운송 가능 아크 집합",
      "source": "plantWarehouseCost filtered by Warehouse ID in W"
    },
    {
      "name": "warehouse_customer_arcs",
      "symbol": "A_wc",
      "description": "warehouse -> customer 배정 가능 아크 집합",
      "source": "warehouseCustomerCost filtered by Warehouse ID in W"
    }
  ],
  "parameters": [
    {
      "name": "plant_supply",
      "symbol": "s[p]",
      "index": ["plant"],
      "description": "각 plant의 Product Qty",
      "source": "plant.Product Qty",
      "unit": "qty"
    },
    {
      "name": "customer_demand",
      "symbol": "d[c]",
      "index": ["customer"],
      "description": "각 customer의 Do Qty",
      "source": "customer.Do Qty",
      "unit": "qty"
    },
    {
      "name": "warehouse_capacity",
      "symbol": "cap[w]",
      "index": ["warehouse"],
      "description": "각 warehouse의 throughput capacity",
      "source": "warehouse.Capacity Qty",
      "unit": "qty"
    },
    {
      "name": "warehouse_fixed_cost",
      "symbol": "fc[w]",
      "index": ["warehouse"],
      "description": "warehouse 고정비",
      "source": "warehouse.Fixed Cost",
      "unit": "cost"
    },
    {
      "name": "warehouse_operation_cost",
      "symbol": "oc[w]",
      "index": ["warehouse"],
      "description": "warehouse 처리 물량 단위당 운영비",
      "source": "warehouse.Operation Cost",
      "unit": "cost/qty"
    },
    {
      "name": "plant_warehouse_transport_cost",
      "symbol": "cpw[p,w]",
      "index": ["plant", "warehouse"],
      "description": "plant -> warehouse 물량 단위당 운송비",
      "source": "plantWarehouseCost.Trns Cost",
      "unit": "cost/qty"
    },
    {
      "name": "warehouse_customer_transport_cost",
      "symbol": "cwc[w,c]",
      "index": ["warehouse", "customer"],
      "description": "warehouse -> customer 수요 단위당 운송비",
      "source": "warehouseCustomerCost.Trns Cost",
      "unit": "cost/qty"
    },
    {
      "name": "customer_mapping_id",
      "symbol": "map[c]",
      "index": ["customer"],
      "description": "지정된 경우 customer를 특정 warehouse에만 배정하도록 강제하는 매핑",
      "source": "customer.Mapping ID",
      "unit": "identifier"
    },
    {
      "name": "required_warehouse_count",
      "symbol": "K",
      "index": [],
      "description": "정확히 사용해야 하는 warehouse 수",
      "source": "simulation.Warehouse Qty",
      "unit": "count"
    },
    {
      "name": "total_plant_supply",
      "symbol": "S",
      "index": [],
      "description": "모든 plant Product Qty의 총합",
      "source": "sum of plant.Product Qty",
      "unit": "qty"
    }
  ],
  "decision_variables": [
    {
      "name": "open_warehouse",
      "symbol": "y[w]",
      "type": "binary",
      "index": ["warehouse"],
      "description": "warehouse w를 오픈하면 1",
      "source_locations": ["src/network3tier/optimizer.py"]
    },
    {
      "name": "assign_customer",
      "symbol": "x[w,c]",
      "type": "binary",
      "index": ["warehouse", "customer"],
      "description": "customer c를 warehouse w에 배정하면 1; 정의역은 A_wc",
      "source_locations": ["src/network3tier/optimizer.py"]
    },
    {
      "name": "plant_to_warehouse_flow",
      "symbol": "f[p,w]",
      "type": "integer",
      "index": ["plant", "warehouse"],
      "description": "plant p에서 warehouse w로 보내는 정수 물량; 정의역은 A_pw, 상한은 plant Product Qty",
      "source_locations": ["src/network3tier/optimizer.py"]
    }
  ],
  "constraints": [
    {
      "id": "customer_single_sourcing",
      "family": "assignment",
      "expression_summary": "for each c in C: sum_{w:(w,c) in A_wc} x[w,c] = 1"
    },
    {
      "id": "mapping_enforcement",
      "family": "assignment",
      "expression_summary": "for each c with map[c]: x[map[c], c] = 1"
    },
    {
      "id": "warehouse_open_if_assigned",
      "family": "activation",
      "expression_summary": "for each w in W: sum_{c:(w,c) in A_wc} x[w,c] >= y[w]"
    },
    {
      "id": "mapped_warehouse_must_open",
      "family": "activation",
      "expression_summary": "for each mapped warehouse w: y[w] = 1"
    },
    {
      "id": "warehouse_count_exact",
      "family": "cardinality",
      "expression_summary": "sum_{w in W} y[w] = K"
    },
    {
      "id": "warehouse_outbound_not_exceed_inbound",
      "family": "flow_balance",
      "expression_summary": "for each w in W: sum_{c:(w,c) in A_wc} d[c] * x[w,c] <= sum_{p:(p,w) in A_pw} f[p,w]"
    },
    {
      "id": "warehouse_outbound_capacity",
      "family": "capacity",
      "expression_summary": "for each w in W: sum_{c:(w,c) in A_wc} d[c] * x[w,c] <= cap[w] * y[w]"
    },
    {
      "id": "plant_supply_limit",
      "family": "supply",
      "expression_summary": "for each p in P: sum_{w:(p,w) in A_pw} f[p,w] <= s[p]"
    },
    {
      "id": "total_inbound_equals_total_supply",
      "family": "supply",
      "expression_summary": "sum_{(p,w) in A_pw} f[p,w] = S"
    }
  ],
  "objective": {
    "name": "minimize_total_cost",
    "sense": "min",
    "terms": [
      {
        "name": "warehouse_fixed_cost_term",
        "expression_summary": "sum_{w in W} fc[w] * y[w]"
      },
      {
        "name": "plant_warehouse_transport_cost_term",
        "expression_summary": "sum_{(p,w) in A_pw} cpw[p,w] * f[p,w]"
      },
      {
        "name": "warehouse_customer_transport_cost_term",
        "expression_summary": "sum_{(w,c) in A_wc} d[c] * cwc[w,c] * x[w,c]"
      },
      {
        "name": "warehouse_operation_cost_term",
        "expression_summary": "sum_{(w,c) in A_wc} d[c] * oc[w] * x[w,c]"
      }
    ]
  },
  "data_mapping": [
    {
      "source_name": "warehouse.Active Y/N",
      "mapped_to": "set W membership filter with values Y or F"
    },
    {
      "source_name": "simulation.Warehouse Qty",
      "mapped_to": "required_warehouse_count K"
    },
    {
      "source_name": "plant.Product Qty",
      "mapped_to": "plant_supply s[p] and total_plant_supply S"
    },
    {
      "source_name": "warehouse.Capacity Qty",
      "mapped_to": "warehouse_capacity cap[w]"
    },
    {
      "source_name": "customer.Do Qty",
      "mapped_to": "customer_demand d[c] and assignment-weighted transport/operation cost"
    }
  ],
  "notes": [
    "Customer demand is always fully assigned because each customer must choose exactly one eligible warehouse.",
    "Shipment Qty and distance data are used for leadtime and coverage post-processing, not for the optimization objective."
  ]
}
